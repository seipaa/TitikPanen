# AgroMesh AI - Backend Environment Variables

# Application
APP_NAME=AgroMesh AI
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./agromesh.db

# MinIO / S3 Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agromesh-images
MINIO_SECURE=false

# AI Service (user will provide endpoint)
AI_API_URL=http://localhost:8001/predict
AI_API_KEY=your-ai-api-key

# BMKG API (public, no key required)
BMKG_API_URL=https://api.bmkg.go.id

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080